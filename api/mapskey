export default async function handler(req, res) {
  const apiKey = process.env.GOOGLE_PLACES_API_KEY;
  if (!apiKey) return res.status(500).send('// API key not configured');
  // Redirect to the real Google Maps JS API script with the key injected server-side
  res.redirect(302, `https://maps.googleapis.com/maps/api/js?key=${apiKey}&callback=initMap&libraries=geometry`);
}
